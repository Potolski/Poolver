# Reown AppKit project id — public, safe to expose.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Solana RPC for browser reads. Public devnet is rate-limited; use Helius free
# tier for sustained dev/demo. Public, safe to expose.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Server-only RPC for /api/kyc/issue and /api/faucet. Falls back to
# NEXT_PUBLIC_SOLANA_RPC if unset. Optional.
SOLANA_RPC=

# SERVER-ONLY. Base58 encoding of the deploy keypair's 64-byte secret key.
# DO NOT prefix with NEXT_PUBLIC_ — that would leak the keypair into the
# browser bundle.
#
# Convert from a Solana CLI keypair JSON file with:
#   node -e "const fs=require('fs'),bs58=require('bs58').default;\
#     console.log(bs58.encode(Uint8Array.from(JSON.parse(\
#     fs.readFileSync('../deploy-keypair.json')))))"
ADMIN_KEYPAIR_BASE58=
